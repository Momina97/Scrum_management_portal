<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Attendance Records Form View -->
    <record id="view_hik_attendance_record_form" model="ir.ui.view">
        <field name="name">hik.attendance.record.form</field>
        <field name="model">hik.attendance.record</field>
        <field name="arch" type="xml">
            <form>
                <header>
                    <button name="action_map_employee" string="Map Employee" type="object" class="btn-primary"
                            invisible="['|', ('employee_id', '!=', False), ('state', '=', 'processed')]"/>
                    <button name="action_create_attendance" string="Create Attendance" type="object" class="btn-primary"
                            invisible="['|', ('employee_id', '=', False), ('state', '=', 'processed')]"/>
                    <field name="state" widget="statusbar" statusbar_visible="new,processed,error"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <h1>
                            <field name="name"/>
                        </h1>
                    </div>
                    <group>
                        <group>
                            <field name="config_id"/>
                            <field name="external_id"/>
                            <field name="employee_code"/>
                            <field name="card_number"/>
                            <field name="person_name"/>
                            <field name="auth_datetime"/>
                        </group>
                        <group>
                            <field name="device_name"/>
                            <field name="direction"/>
                            <field name="attendance_status"/>
                            <field name="auth_result"/>
                            <field name="auth_type"/>
                            <field name="temperature"/>
                            <field name="employee_id"/>
                            <field name="attendance_id"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Raw Data">
                            <field name="raw_data"/>
                        </page>
                        <page string="Notes">
                            <field name="notes"/>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <!-- Attendance Records List View -->
    <record id="view_hik_attendance_record_list" model="ir.ui.view">
        <field name="name">hik.attendance.record.list</field>
        <field name="model">hik.attendance.record</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="employee_code"/>
                <field name="person_name"/>
                <field name="auth_datetime"/>
                <field name="device_name"/>
                <field name="direction"/>
                <field name="attendance_status"/>
                <field name="employee_id"/>
                <field name="attendance_id"/>
                <field name="state"/>
            </list>
        </field>
    </record>

    <!-- Attendance Records Search View -->
    <record id="view_hik_attendance_record_search" model="ir.ui.view">
        <field name="name">hik.attendance.record.search</field>
        <field name="model">hik.attendance.record</field>
        <field name="arch" type="xml">
            <search>
                <field name="name"/>
                <field name="employee_code"/>
                <field name="person_name"/>
                <field name="card_number"/>
                <field name="device_name"/>
                <field name="employee_id"/>
                <separator/>
                <filter string="New" name="new" domain="[('state', '=', 'new')]"/>
                <filter string="Processed" name="processed" domain="[('state', '=', 'processed')]"/>
                <filter string="Error" name="error" domain="[('state', '=', 'error')]"/>
                <separator/>
                <filter string="Without Employee" name="no_employee" domain="[('employee_id', '=', False)]"/>
                <filter string="With Employee" name="with_employee" domain="[('employee_id', '!=', False)]"/>
                <group expand="0" string="Group By">
                    <filter string="Status" name="group_by_state" context="{'group_by': 'state'}"/>
                    <filter string="Employee" name="group_by_employee" context="{'group_by': 'employee_id'}"/>
                    <filter string="Device" name="group_by_device" context="{'group_by': 'device_name'}"/>
                    <filter string="Date" name="group_by_date" context="{'group_by': 'auth_datetime'}"/>
                </group>
            </search>
        </field>
    </record>

    <!-- Attendance Records Action -->
    <record id="action_hik_attendance_record" model="ir.actions.act_window">
        <field name="name">Attendance Records</field>
        <field name="res_model">hik.attendance.record</field>
        <field name="binding_model_id" ref="model_hik_attendance_record"/>
        <field name="binding_view_types">list</field>
        <field name="binding_type">action</field>
        <field name="view_mode">list,form</field>
        <field name="search_view_id" ref="view_hik_attendance_record_search"/>
        <field name="context">{'search_default_new': 1}</field>
        <field name="limit">100</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                No attendance records found
            </p>
            <p>
                Attendance records will be imported from the external database. 
                Click on "Database Configurations" in the menu and then "Fetch Attendance Now" to import records.
            </p>
        </field>
    </record>

    <!-- Menu items -->
    <menuitem id="menu_hik_central_attendance" 
              name="HikCentral Attendance" 
              parent="hr_attendance.menu_hr_attendance_root" 
              sequence="100"
              groups="base.group_system"/>
              
    <menuitem id="menu_hik_central_db_config" 
              name="Database Configurations" 
              parent="menu_hik_central_attendance" 
              action="action_hik_central_db_config" 
              sequence="10"
              groups="base.group_system"/>
              
    <menuitem id="menu_hik_central_db_config_wizard" 
              name="Configure New Connection" 
              parent="menu_hik_central_attendance" 
              action="action_hik_central_db_config_wizard" 
              sequence="11"
              groups="base.group_system"/>
              
    <!-- Action for analyzing attendance status -->
    <record id="action_analyze_attendance_status" model="ir.actions.server">
        <field name="name">Analyze Attendance Status</field>
        <field name="model_id" ref="model_hik_attendance_record"/>
        <field name="binding_model_id" ref="model_hik_attendance_record"/>
        <field name="binding_view_types">list</field>
        <field name="state">code</field>
        <field name="code">action = model.action_analyze_attendance_status()</field>
    </record>
    
    <!-- Action for reprocessing attendance records -->
    <record id="action_reprocess_attendance_records" model="ir.actions.server">
        <field name="name">Reprocess Attendance Records</field>
        <field name="model_id" ref="model_hik_attendance_record"/>
        <field name="binding_model_id" ref="model_hik_attendance_record"/>
        <field name="binding_view_types">list</field>
        <field name="state">code</field>
        <field name="code">action = model.action_reprocess_attendance_records()</field>
    </record>

    <!-- Menu item for Attendance Records -->
    <menuitem id="menu_hik_attendance_record" 
              name="Attendance Records" 
              parent="menu_hik_central_attendance" 
              action="action_hik_attendance_record" 
              sequence="20"
              groups="base.group_system"/>
</odoo>
