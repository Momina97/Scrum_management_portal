<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">
    <t t-name="scrum_management.VelocityChart">
        <div class="bg-white p-4 rounded-4 shadow-sm border mb-4">

            <!-- HEADER & FILTERS -->
            <div class="d-flex justify-content-between align-items-center mb-3">
                <div>
                    <h5 class="fw-bold mb-0 text-dark">
                        <i class="fa fa-line-chart text-primary me-2"></i>Velocity Trends
                    </h5>
                    <small class="text-muted">Estimated vs Delivered</small>
                </div>

                <!-- Instant Filters -->
                <div class="d-flex align-items-center gap-3">

                    <!-- 🚀 UPDATED: Expanded Standard Rolling Average Windows -->
                    <div class="btn-group shadow-sm" role="group">
                        <span class="btn btn-sm btn-light border-secondary disabled text-dark fw-bold">Rolling Window:</span>
                        <button type="button"
                                t-attf-class="btn btn-sm #{state.rollingWindow === 2 ? 'btn-primary' : 'btn-outline-secondary'}"
                                t-on-click="() => this.setRollingWindow(2)">2</button>
                        <button type="button"
                                t-attf-class="btn btn-sm #{state.rollingWindow === 3 ? 'btn-primary' : 'btn-outline-secondary'}"
                                t-on-click="() => this.setRollingWindow(3)">3</button>
                        <button type="button"
                                t-attf-class="btn btn-sm #{state.rollingWindow === 5 ? 'btn-primary' : 'btn-outline-secondary'}"
                                t-on-click="() => this.setRollingWindow(5)">5</button>
                        <button type="button"
                                t-attf-class="btn btn-sm #{state.rollingWindow === 8 ? 'btn-primary' : 'btn-outline-secondary'}"
                                t-on-click="() => this.setRollingWindow(8)">8</button>
                        <button type="button"
                                t-attf-class="btn btn-sm #{state.rollingWindow === 10 ? 'btn-primary' : 'btn-outline-secondary'}"
                                t-on-click="() => this.setRollingWindow(10)">10</button>
                    </div>

                    <!-- Existing Time Filters -->
                    <div class="btn-group shadow-sm" role="group">
                        <button type="button"
                                t-attf-class="btn btn-sm #{state.filter === 'last_5' ? 'btn-primary' : 'btn-outline-secondary'}"
                                t-on-click="() => this.setFilter('last_5')">Last 5 Sprints</button>
                        <button type="button"
                                t-attf-class="btn btn-sm #{state.filter === 'last_10' ? 'btn-primary' : 'btn-outline-secondary'}"
                                t-on-click="() => this.setFilter('last_10')">Last 10 Sprints</button>
                        <button type="button"
                                t-attf-class="btn btn-sm #{state.filter === 'all' ? 'btn-primary' : 'btn-outline-secondary'}"
                                t-on-click="() => this.setFilter('all')">All Sprints</button>
                    </div>
                </div>
            </div>

            <!-- EXPLICIT INDICATORS ROW -->
            <div class="d-flex justify-content-center gap-5 mb-3 pb-3 border-bottom text-muted" style="font-size: 0.95rem;">
                <div title="The average points delivered across all currently visible sprints." style="cursor: help;">
                    <span>Avg. Delivered: </span>
                    <strong class="text-primary fs-6"><t t-esc="state.metrics.average"/> pts</strong>
                </div>
                <div title="The average points delivered over your 3 most recently completed sprints." style="cursor: help;">
                    <span>Last 3 Delivered: </span>
                    <strong class="text-primary fs-6"><t t-esc="state.metrics.last3"/> pts</strong>
                </div>
                <div title="The average of the 3 sprints where you delivered the most points." style="cursor: help;">
                    <span>Top 3 Delivered: </span>
                    <strong class="text-primary fs-6"><t t-esc="state.metrics.best3"/> pts</strong>
                </div>
                <div title="The average of the 3 sprints where you delivered the fewest points." style="cursor: help;">
                    <span>Bottom 3 Delivered: </span>
                    <strong class="text-primary fs-6"><t t-esc="state.metrics.worst3"/> pts</strong>
                </div>
            </div>

            <!-- CHART CANVAS -->
            <div style="position: relative; height: 320px; width: 100%;">
                <canvas t-ref="chartCanvas"></canvas>
            </div>

        </div>
    </t>
</templates>