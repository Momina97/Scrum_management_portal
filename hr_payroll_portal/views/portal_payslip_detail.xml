<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <template id="portal_payslip_detail" name="Payslip Detail">
        <t t-call="portal.portal_layout">

            <div class="container mt-4">

                <!-- Payslip Header Info -->
                <div class="card shadow-sm mb-4">
                    <div class="card-header d-flex justify-content-between align-items-center">
                        <h5 class="mb-0">
                            <t t-esc="payslip.name"/>
                        </h5>
                        <a t-attf-href="/my/payslips/#{payslip.id}/download"
                           class="btn btn-sm btn-primary">
                            Download PDF
                        </a>
                    </div>
                    <div class="card-body">
                        <div class="row mb-2">
                            <div class="col-sm-4 fw-bold">Employee</div>
                            <div class="col-sm-8">
                                <t t-esc="payslip.employee_id.name"/>
                            </div>
                        </div>
                        <div class="row mb-2">
                            <div class="col-sm-4 fw-bold">Period</div>
                            <div class="col-sm-8">
                                <span t-field="payslip.date_from"
                                      t-options='{"widget": "date"}'/>
                                —
                                <span t-field="payslip.date_to"
                                      t-options='{"widget": "date"}'/>
                            </div>
                        </div>
                        <div class="row mb-2">
                            <div class="col-sm-4 fw-bold">Contract</div>
                            <div class="col-sm-8">
                                <t t-esc="payslip.contract_id.name"/>
                            </div>
                        </div>
                        <div class="row mb-2">
                            <div class="col-sm-4 fw-bold">Structure</div>
                            <div class="col-sm-8">
                                <t t-esc="payslip.struct_id.name"/>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Earnings -->
                <div class="card shadow-sm mb-4">
                    <div class="card-header">
                        <h6 class="mb-0">Earnings</h6>
                    </div>
                    <div class="card-body p-0">
                        <table class="table table-sm mb-0">
                            <thead class="table-light">
                                <tr>
                                    <th>Description</th>
                                    <th class="text-end">Amount</th>
                                </tr>
                            </thead>
                            <tbody>
                                <t t-foreach="earnings" t-as="line">
                                    <tr>
                                        <td><t t-esc="line.name"/></td>
                                        <td class="text-end">
                                            <t t-esc="line.total"/>
                                        </td>
                                    </tr>
                                </t>
                            </tbody>
                            <tfoot class="table-light">
                                <tr>
                                    <td class="fw-bold">Gross</td>
                                    <td class="text-end fw-bold">
                                        <t t-esc="payslip.gross_wage"/>
                                    </td>
                                </tr>
                            </tfoot>
                        </table>
                    </div>
                </div>

                <!-- Deductions -->
                <div class="card shadow-sm mb-4">
                    <div class="card-header">
                        <h6 class="mb-0">Deductions</h6>
                    </div>
                    <div class="card-body p-0">
                        <table class="table table-sm mb-0">
                            <thead class="table-light">
                                <tr>
                                    <th>Description</th>
                                    <th class="text-end">Amount</th>
                                </tr>
                            </thead>
                            <tbody>
                                <t t-foreach="deductions" t-as="line">
                                    <tr>
                                        <td><t t-esc="line.name"/></td>
                                        <td class="text-end">
                                            <t t-esc="line.total"/>
                                        </td>
                                    </tr>
                                </t>
                            </tbody>
                        </table>
                    </div>
                </div>

                <!-- Net Pay -->
                <div class="card shadow-sm mb-4">
                    <div class="card-body">
                        <div class="d-flex justify-content-between align-items-center">
                            <h5 class="mb-0">Net Pay</h5>
                            <h4 class="mb-0 text-success">
                                <t t-esc="payslip.net_wage"/>
                            </h4>
                        </div>
                    </div>
                </div>

                <div class="mt-3">
                    <a href="/my/payslips" class="btn btn-secondary">
                        Back to Payslips
                    </a>
                </div>

            </div>

        </t>
    </template>

</odoo>