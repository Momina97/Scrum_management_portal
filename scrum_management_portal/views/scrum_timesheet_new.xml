<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ============================================================
         LOG TIME — task level (works for both tasks and subtasks)
    ============================================================ -->
    <template id="portal_timesheet_new" name="Log Time">
        <t t-call="portal.portal_layout">
            <div class="cymax_scrum_page">

                <div class="scrum_page_header">
                    <a t-attf-href="/my/scrum/projects/#{project.id}/tasks/#{task.id}?tab=timesheets"
                    class="scrum_back_link">
                        <i class="fa fa-arrow-left me-1"/><t t-esc="task.name"/>
                    </a>
                    <h1 class="scrum_page_title mt-1">Log Time</h1>
                    <p class="scrum_page_subtitle">
                        Logging time against: <strong><t t-esc="task.name"/></strong>
                    </p>
                </div>

                <div class="scrum_edit_layout">
                    <div class="scrum_edit_main">
                        <div class="scrum_form_card" style="max-width: 100%;">

                            <t t-if="error">
                                <div class="scrum_alert_danger">
                                    <i class="fa fa-exclamation-circle me-2"/>
                                    <t t-esc="error"/>
                                </div>
                            </t>

                            <form method="POST"
                                t-attf-action="/my/scrum/projects/#{project.id}/tasks/#{task.id}/timesheets/new">
                                <input type="hidden" name="csrf_token"
                                    t-att-value="request.csrf_token()"/>

                                <div class="scrum_form_group">
                                    <label for="date" class="scrum_form_label">Date</label>
                                    <input type="date" class="scrum_form_input"
                                        id="date" name="date" required="1"/>
                                </div>

                                <div class="scrum_form_group">
                                    <label for="unit_amount" class="scrum_form_label">Hours</label>
                                    <input type="number" step="any" min="0.01"
                                        class="scrum_form_input"
                                        id="unit_amount" name="unit_amount" required="1"/>
                                </div>

                                <div class="scrum_form_group">
                                    <label for="name" class="scrum_form_label">Description</label>
                                    <input type="text" class="scrum_form_input"
                                        id="name" name="name"
                                        placeholder="What did you work on?"/>
                                </div>

                                <div class="d-flex gap-2 mt-4">
                                    <button type="submit" class="scrum_btn_primary">
                                        <i class="fa fa-check me-1"/>Log Time
                                    </button>
                                    <a t-attf-href="/my/scrum/projects/#{project.id}/tasks/#{task.id}?tab=timesheets"
                                    class="scrum_btn_outline">
                                        Cancel
                                    </a>
                                </div>
                            </form>
                        </div>
                    </div>

                    <div class="scrum_edit_sidebar">
                        <div class="scrum_info_panel">
                            <div class="scrum_info_panel_header">
                                <i class="fa fa-info-circle me-2"/>Details
                            </div>
                            <div class="scrum_info_row">
                                <span class="scrum_info_label">Project</span>
                                <span class="scrum_info_value"><t t-esc="project.name"/></span>
                            </div>
                            <div class="scrum_info_row" t-if="task.sprint_id">
                                <span class="scrum_info_label">Sprint</span>
                                <span class="scrum_info_value"><t t-esc="task.sprint_id.name"/></span>
                            </div>
                            <div class="scrum_info_row">
                                <span class="scrum_info_label">Task</span>
                                <span class="scrum_info_value"><t t-esc="task.name"/></span>
                            </div>
                            <div class="scrum_info_row">
                                <span class="scrum_info_label">Employee</span>
                                <span class="scrum_info_value"><t t-esc="employee.name"/></span>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </t>
    </template>

</odoo>
