<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Process Attendance Wizard Form -->
    <record id="view_hik_process_attendance_wizard_form" model="ir.ui.view">
        <field name="name">hik.process.attendance.wizard.form</field>
        <field name="model">hik.process.attendance.wizard</field>
        <field name="arch" type="xml">
            <form>
                <group>
                    <field name="action_type" widget="radio"/>
                    <field name="attendance_ids" invisible="1"/>
                </group>
                <footer>
                    <button name="action_process" string="Process" type="object" class="btn-primary"/>
                    <button string="Cancel" class="btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

    <!-- Process Attendance Wizard Action -->
    <record id="action_hik_process_attendance_wizard" model="ir.actions.act_window">
        <field name="name">Process Attendance Records</field>
        <field name="res_model">hik.process.attendance.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
        <field name="binding_model_id" ref="model_hik_attendance_record"/>
    </record>
</odoo>
