<?xml version="1.0" encoding="utf-8"?>
<odoo noupdate="1">
    <!-- Cron job to sync attendance data -->
    <record id="ir_cron_hik_central_sync_attendance" model="ir.cron">
        <field name="name">HikCentral: Sync Attendance Data</field>
        <field name="model_id" ref="model_hik_central_db_config"/>
        <field name="state">code</field>
        <field name="code">model.fetch_attendance_data()</field>
        <field name="user_id" ref="base.user_admin"/>
        <field name="interval_type">minutes</field>
        <field name="interval_number">20</field>
        <field name="active" eval="True"/>
    </record>

    
        <!-- Cron job to automatically process attendance records -->
    <record id="ir_cron_auto_process_attendance_records" model="ir.cron">
        <field name="name">HikCentral: Auto Process Attendance Records</field>
        <field name="model_id" ref="model_hik_attendance_record"/>
        <field name="state">code</field>
        <field name="code">model.auto_process_attendance_records()</field>
        <field name="user_id" ref="base.user_admin"/>
        <field name="interval_type">minutes</field>
        <field name="interval_number">20</field>
        <field name="active" eval="True"/>
    </record>


    <!-- Cron job to update open attendances -->
    <record id="ir_cron_update_open_attendances" model="ir.cron">
        <field name="name">HikCentral: Update Open Attendances</field>
        <field name="model_id" ref="model_hr_attendance"/>
        <field name="state">code</field>
        <field name="code">model.update_open_attendances()</field>
        <field name="user_id" ref="base.user_admin"/>
        <field name="interval_type">minutes</field>
        <field name="interval_number">30</field>
        <field name="active" eval="True"/>
    </record>
    
    <!-- Cron job for automatic checkout at end of day -->
    <record id="ir_cron_auto_checkout_missing_employees" model="ir.cron">
        <field name="name">HikCentral: Auto-Checkout Missing Employees (Fixed 17:30)</field>
        <field name="model_id" ref="model_hr_attendance"/>
        <field name="state">code</field>
        <field name="code">model.auto_checkout_missing_employees()</field>
        <field name="user_id" ref="base.user_admin"/>
        <field name="interval_type">days</field>
        <field name="interval_number">1</field>
        <field name="nextcall" eval="(datetime.now().replace(hour=23, minute=30, second=0)).strftime('%Y-%m-%d %H:%M:%S')" />
        <field name="active" eval="True"/>
    </record>

</odoo>
