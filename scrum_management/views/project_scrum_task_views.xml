<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="quick_create_scrum_task_form" model="ir.ui.view">
        <field name="name">project.task.scrum.quick.create</field>
        <field name="model">project.task</field>
        <field name="priority">1000</field>
        <field name="arch" type="xml">
            <form>
                <group>
                    <field name="name" placeholder="Task Title..."/>
                    <field name="project_id" invisible="1"/>
                    <field name="sprint_id" domain="[('project_id', '=', project_id), ('state', '!=', 'completed')]"/>
                     <field name="story_point_selection" string="Story Points"/>
                    <field name="user_ids" widget="many2many_avatar_user"/>
                </group>
            </form>
        </field>
    </record>

    <record id="project_scrum_task_form_view" model="ir.ui.view">
        <field name="name">project.task.scrum.form</field>
        <field name="model">project.task</field>
        <field name="inherit_id" ref="project.view_task_form2"/>
        <field name="arch" type="xml">

            <xpath expr="//sheet" position="before">
                <header>
                    <field name="stage_id"
                           widget="statusbar"
                           options="{'clickable': '1'}"
                           invisible="not project_id"
                           domain="[('project_type', '=', 'scrum')]"/>
                </header>
            </xpath>

            <xpath expr="//field[@name='state' and @widget='statusbar']" position="replace"/>
            <xpath expr="//field[@name='stage_id' and not(@widget='statusbar')]" position="attributes">
                <attribute name="invisible">1</attribute>
            </xpath>
            <xpath expr="//sheet" position="inside">
                <group invisible="1">
                    <field name="subtask_count"/>
                </group>
            </xpath>
            <xpath expr="//field[@name='user_ids']" position="after">
                <field name="assigned_by_id"/>
                <field name="sprint_id"
                       domain="[('project_id', '=', project_id), ('state', '!=', 'completed')]"
                       options="{'no_open': True, 'no_create': True}"/>
                 <field name="story_point_selection"/>
                <field name="priority" invisible="1"/>
                <field name="state"
                       string="State"
                       widget="selection"
                       options="{'no_create': True}"/>
            </xpath>

            <xpath expr="//notebook" position="inside">
                <page string="Blocked By" name="blocked_by">
                    <field name="blocked_by_ids" context="{'default_project_id': project_id}">
                        <list editable="bottom">
                            <field name="row_number" string="#" readonly="1" width="40"/>
                            <field name="name"/>
                            <field name="user_ids" widget="many2many_avatar_user"/>
                            <field name="stage_id" options="{'no_open': True, 'no_create': True}"/>
                        </list>
                    </field>
                </page>
            </xpath>

            <xpath expr="//field[@name='child_ids']/list" position="attributes">
                <attribute name="default_order">create_date desc</attribute>
            </xpath>
            <xpath expr="//field[@name='child_ids']/list/field[1]" position="before">
                <field name="row_number" string="#" readonly="1" width="40"/>
            </xpath>
        </field>
    </record>

    <record id="view_scrum_backlog_global_kanban" model="ir.ui.view">
        <field name="name">project.task.scrum.backlog.global.kanban</field>
        <field name="model">project.task</field>
        <field name="arch" type="xml">
            <kanban default_group_by="project_id" class="o_kanban_small_column" sample="1" quick_create_view="scrum_management.quick_create_scrum_task_form">
                <field name="name"/><field name="color"/><field name="priority"/><field name="stage_id"/><field name="user_ids"/>
                <field name="story_points"/><field name="project_id"/><field name="date_deadline"/><field name="tag_ids"/>
                <field name="attachment_ids"/><field name="state"/>
                <templates>
                    <t t-name="card">
                        <div class="oe_kanban_global_click shadow-sm" style="border-left: 5px solid #7c3aed !important; border: 1px solid #e2e8f0; border-radius: 8px; margin-bottom: 8px;">
                            <div class="oe_kanban_content p-2">
                                <div class="o_kanban_record_top mb-1">
                                    <div class="o_kanban_record_headings">
                                        <div class="d-flex align-items-center justify-content-between">
                                            <span t-if="record.stage_id.value" class="badge rounded-pill text-dark border fw-normal" style="background-color: #f1f5f9; font-size: 10px;">
                                                <t t-esc="record.stage_id.value"/>
                                            </span>
                                            <div class="o_dropdown_kanban dropdown">
                                                <a class="dropdown-toggle o-no-caret btn p-0 text-muted" role="button" data-bs-toggle="dropdown" href="#" aria-label="Dropdown">
                                                    <span class="fa fa-ellipsis-v"/>
                                                </a>
                                                <div class="dropdown-menu" role="menu">
                                                    <a role="menuitem" type="edit" class="dropdown-item">Edit</a>
                                                    <a role="menuitem" type="delete" class="dropdown-item">Delete</a>
                                                </div>
                                            </div>
                                        </div>
                                        <div class="mt-1 fw-bold text-dark fs-6 text-truncate">
                                            <field name="name"/>
                                        </div>
                                    </div>
                                </div>
                                <div class="mb-2">
                                    <field name="tag_ids" widget="many2many_tags" options="{'color_field': 'color'}"/>
                                </div>
                                <div class="d-flex justify-content-between align-items-center mt-2 pt-2 border-top">
                                    <div class="d-flex gap-3 text-muted small">
                                        <div title="Story Points" class="d-flex align-items-center" t-if="record.story_points.raw_value > 0">
                                            <i class="fa fa-cubes me-1" style="color: #7c3aed;"></i>
                                            <field name="story_points"/>
                                        </div>
                                        <div t-if="record.date_deadline.raw_value" t-attf-class="d-flex align-items-center" title="Deadline">
                                            <i class="fa fa-clock-o me-1"></i>
                                            <field name="date_deadline" widget="remaining_days"/>
                                        </div>
                                    </div>
                                    <div class="ms-auto">
                                        <field name="user_ids" string="Owners" widget="many2many_avatar_user"/>
                                        <field name="assigned_by_id" string="Assigned By"/>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>

    <record id="view_scrum_active_tasks_global_kanban" model="ir.ui.view">
        <field name="name">project.task.scrum.active.tasks.global.kanban</field>
        <field name="model">project.task</field>
        <field name="arch" type="xml">
            <kanban default_group_by="project_id" class="o_kanban_small_column" sample="1" quick_create_view="scrum_management.quick_create_scrum_task_form">
                <field name="name"/><field name="sprint_id"/><field name="stage_id"/><field name="story_points"/><field name="user_ids"/>
                <field name="priority"/><field name="project_id"/><field name="state"/><field name="assigned_by_id"/>
                <templates>
                    <t t-name="card">
                        <div class="oe_kanban_global_click shadow-sm" style="border-left: 5px solid #3b82f6 !important; border: 1px solid #e2e8f0; border-radius: 8px; margin-bottom: 8px;">
                            <div class="oe_kanban_content p-2">
                                <div class="o_kanban_record_top mb-1">
                                    <div class="o_kanban_record_headings">
                                        <div class="d-flex align-items-center justify-content-between">
                                            <t t-if="record.sprint_id and record.sprint_id.raw_value">
                                                <span class="badge rounded-pill fw-bold" style="background-color: #eff6ff; color: #2563eb; border: 1px solid #dbeafe; font-size: 10px;">
                                                    <i class="fa fa-retweet me-1"></i>
                                                    <field name="sprint_id"/> </span>
                                            </t>
                                            <div class="o_dropdown_kanban dropdown">
                                                <a class="dropdown-toggle o-no-caret btn p-0 text-muted" role="button" data-bs-toggle="dropdown" href="#"><span class="fa fa-ellipsis-v"/></a>
                                                <div class="dropdown-menu" role="menu">
                                                    <a role="menuitem" type="edit" class="dropdown-item">Edit</a>
                                                </div>
                                            </div>
                                        </div>
                                        <div class="mt-2 fw-bold text-dark fs-6 text-truncate">
                                            <field name="name"/>
                                        </div>
                                    </div>
                                </div>
                                <div class="d-flex align-items-center flex-wrap gap-1 mb-2" style="font-size: 0.85em;">
                                    <field name="stage_id" widget="badge"/>
                                </div>
                                <div class="d-flex justify-content-between align-items-center mt-2 pt-2 border-top">
                                    <div class="d-flex gap-3 text-muted small">
                                        <div title="Story Points" class="d-flex align-items-center fw-bold text-primary" t-if="record.story_points and record.story_points.raw_value > 0">
                                            <i class="fa fa-cubes me-1"></i>
                                            <field name="story_points"/>
                                        </div>
                                    </div>
                                    <div class="ms-auto">
                                        <div class="d-flex flex-column align-items-end">
                                            <field name="user_ids" widget="many2many_avatar_user"/>
                                            <small class="text-muted" t-if="record.assigned_by_id and record.assigned_by_id.raw_value">
                                                Assigned by: <field name="assigned_by_id"/>
                                            </small>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>

    <record id="view_project_task_backlog_list" model="ir.ui.view">
        <field name="name">project.task.backlog.list</field>
        <field name="model">project.task</field>
        <field name="arch" type="xml">
            <list editable="bottom" default_order="create_date desc">
                <field name="row_number" string="#" readonly="1" width="40"/>
                <field name="name"/>
                <field name="project_id"/>
                <field name="story_points" sum="Total SP"/>
                <field name="stage_id"/>
                <field name="priority" widget="priority"/>
                <field name="user_ids" string="Owners" widget="many2many_avatar_user"/>
                <field name="assigned_by_id" string="Assigned By"/>
                <field name="create_date" invisible="1"/>
                <field name="is_closed" column_invisible="1"/>
            </list>
        </field>
    </record>

    <record id="view_task_form_owner_label" model="ir.ui.view">
        <field name="name">project.task.form.owner.label</field>
        <field name="model">project.task</field>
        <field name="inherit_id" ref="project.view_task_form2"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='user_ids']" position="attributes">
                <attribute name="string">Owners</attribute>
            </xpath>
        </field>
    </record>

    <record id="view_task_tree_owner_label" model="ir.ui.view">
        <field name="name">project.task.tree.owner.label</field>
        <field name="model">project.task</field>
        <field name="inherit_id" ref="project.view_task_tree2"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='user_ids']" position="attributes">
                <attribute name="string">Owners</attribute>
            </xpath>
        </field>
    </record>

    <record id="project_scrum_task_search_view" model="ir.ui.view">
        <field name="name">project.task.scrum.search</field>
        <field name="model">project.task</field>
        <field name="inherit_id" ref="project.view_task_search_form"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='project_id']" position="after">
                <field name="sprint_id" filter_domain="[('sprint_id.name', 'ilike', self)]"/>
            </xpath>
        </field>
    </record>

    <record id="view_scrum_project_planning_kanban" model="ir.ui.view">
        <field name="name">project.task.scrum.planning.kanban</field>
        <field name="model" >project.task</field>
        <field name="arch" type="xml">
            <kanban default_group_by="sprint_id" class="o_kanban_small_column" create="true" quick_create_view="scrum_management.quick_create_scrum_task_form">
                <field name="name"/><field name="sprint_id"/><field name="stage_id"/><field name="story_points"/><field name="user_ids"/>
                <field name="priority"/><field name="project_id"/><field name="state"/>
                <progressbar field="state" colors='{"1_done": "success", "01_in_progress": "info", "1_canceled": "danger"}'/>
                <templates>
                    <t t-name="card">
                        <div class=" oe_kanban_global_click shadow-sm" style="border-left: 5px solid #3b82f6 !important; border: 1px solid #e2e8f0; border-radius: 8px; margin-bottom: 8px;">
                            <div class="oe_kanban_content p-2">
                                <div class="o_kanban_record_top">
                                    <div class="o_kanban_record_headings">
                                        <strong class="o_kanban_record_title text-dark fs-6"><field name="name"/></strong>
                                    </div>
                                </div>
                                <div class="mt-1 d-flex align-items-center justify-content-between">
                                    <span class="badge rounded-pill text-uppercase border" style="font-size: 9px; background-color: #f8fafc; color: #64748b;">
                                        <field name="stage_id"/>
                                    </span>
                                    <div t-if="record.story_points.raw_value" class="text-primary fw-bold small">
                                        <i class="fa fa-cubes me-1"/> <field name="story_points"/> SP
                                    </div>
                                </div>
                                <div class="o_kanban_record_bottom mt-2 pt-2 border-top d-flex justify-content-between align-items-center">
                                    <div class="small text-muted">
                                        <field name="priority" widget="priority"/>
                                    </div>
                                    <field name="user_ids" string="Owners" widget="many2many_avatar_user"/>
                                    <field name="assigned_by_id" string="Assigned By"/>
                                </div>
                            </div>
                        </div>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>

    <record id="view_scrum_task_board_kanban" model="ir.ui.view">
        <field name="name">project.task.scrum.board.kanban</field>
        <field name="model">project.task</field>
        <field name="arch" type="xml">
            <kanban default_group_by="stage_id" class="o_kanban_small_column o_kanban_project_tasks" quick_create_view="scrum_management.quick_create_scrum_task_form">
                <field name="name"/><field name="stage_id"/><field name="state"/><field name="user_ids"/><field name="story_points"/><field name="sprint_id"/><field name="priority"/>
                <progressbar field="state" colors='{"1_done": "success", "01_in_progress": "info", "04_waiting_normal": "warning", "1_canceled": "danger"}'/>
                <templates>
                    <t t-name="card">
                        <div class="oe_kanban_global_click shadow-sm" style="border-radius: 8px; margin-bottom: 8px;">
                            <div class="oe_kanban_content p-2">
                                <div class="o_kanban_record_top">
                                    <div class="o_kanban_record_headings">
                                        <strong class="text-dark fs-6"><field name="name"/></strong>
                                    </div>
                                </div>
                                <div class="mt-2 d-flex align-items-center justify-content-between">
                                    <div class="d-flex gap-2 align-items-center">
                                        <field name="priority" widget="priority"/>
                                        <t t-if="record.story_points.raw_value">
                                            <span class="badge rounded-pill bg-light text-primary border">
                                                <field name="story_points"/> SP
                                            </span>
                                        </t>
                                    </div>
                                    <field name="user_ids" widget="many2many_avatar_user"/>
                                </div>
                                <div class="o_kanban_record_bottom mt-2 pt-2 border-top d-flex justify-content-between align-items-center">
                                    <div class="small text-muted">
                                        <i class="fa fa-retweet me-1"/> <field name="sprint_id"/>
                                    </div>
                                    <field name="state" widget="project_task_state_selection"/>
                                </div>
                            </div>
                        </div>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>

    <record id="action_scrum_sprint_task_board" model="ir.actions.act_window">
        <field name="name">Sprint Board</field>
        <field name="res_model">project.task</field>
        <field name="view_mode">kanban,list,form</field>
        <field name="domain">[('sprint_id', '=', active_id)]</field>
        <field name="context">{'default_sprint_id': active_id, 'search_default_sprint_id': active_id, 'is_scrum_app': True}</field>
    </record>

    <record id="action_scrum_sprint_task_board_kanban_view" model="ir.actions.act_window.view">
        <field name="sequence" eval="1"/>
        <field name="view_mode">kanban</field>
        <field name="view_id" ref="view_scrum_task_board_kanban"/>
        <field name="act_window_id" ref="action_scrum_sprint_task_board"/>
    </record>

    <record id="action_scrum_active_tasks_sidebar" model="ir.actions.act_window">
        <field name="name">Active Tasks</field>
        <field name="res_model">project.task</field>
        <field name="view_mode">kanban,list,form</field>
        <field name="domain">[
            ('is_scrum_project', '=', True),
            ('sprint_id', '!=', False),
            ('parent_id', '=', False),
            ('state', '!=', '1_done'),
            ('stage_id.category', '!=', 'closed')
        ]</field>
        <field name="context">{'is_scrum_app': True, 'default_project_type': 'scrum', 'group_by': 'project_id'}</field>
        <field name="view_id" ref="view_scrum_active_tasks_global_kanban"/>
    </record>

</odoo>