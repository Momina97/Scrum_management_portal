<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="0">

        <record id="project_project_stage_scrum_backlog" model="project.project.stage">
            <field name="name">Backlog</field>
            <field name="sequence">1</field>
            <field name="project_type">scrum</field>
            <field name="category">backlog</field>
            <field name="fold" eval="False"/>
        </record>

        <record id="project_project_stage_scrum_active" model="project.project.stage">
            <field name="name">Active</field>
            <field name="sequence">2</field>
            <field name="project_type">scrum</field>
            <field name="category">active</field>
            <field name="fold" eval="False"/>
        </record>

        <record id="project_project_stage_scrum_completed" model="project.project.stage">
            <field name="name">Completed / Delivered</field>
            <field name="sequence">3</field>
            <field name="project_type">scrum</field>
            <field name="category">completed</field>
            <field name="fold" eval="False"/>
        </record>

        <record id="project_project_stage_scrum_closed" model="project.project.stage">
            <field name="name">Finalized / Closed</field>
            <field name="sequence">10</field>
            <field name="project_type">scrum</field>
            <field name="category">finalized</field>
            <field name="fold" eval="True"/>
        </record>
    </data>
</odoo>