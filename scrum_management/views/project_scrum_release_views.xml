<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_project_scrum_release_list" model="ir.ui.view">
        <field name="name">project.scrum.release.list</field>
        <field name="model">project.scrum.release</field>
        <field name="type">list</field>
        <field name="arch" type="xml">
            <list string="Releases" create="true" edit="true" delete="true">
                <field name="name"/>
                <field name="project_id"/>
                <field name="release_date"/>
                <field name="state" widget="badge" decoration-success="state == 'validated' or state == 'finalized'" decoration-info="state == 'draft'"/>
            </list>
        </field>
    </record>

    <!-- Release Form View -->
    <record id="view_project_scrum_release_form" model="ir.ui.view">
        <field name="name">project.scrum.release.form</field>
        <field name="model">project.scrum.release</field>
        <field name="type">form</field>
        <field name="arch" type="xml">
            <form string="Release">
                <header>
                    <button name="action_validate" string="Validate" type="object"
                            class="oe_highlight" invisible="state != 'draft'"/>

                    <button name="action_finalize" string="Finalize" type="object"
                            class="oe_highlight" invisible="state != 'validated'"/>

                    <button name="action_set_to_draft" string="Reset to Draft" type="object"
                            invisible="state not in ('validated', 'finalized')"/>

                    <field name="state" widget="statusbar" statusbar_visible="draft,validated,finalized"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <h1>
                            <field name="name" placeholder="e.g., Version 1.2 Release"/>
                        </h1>
                    </div>
                    <group>
                        <group>
                            <field name="project_id"/>
                        </group>
                        <group>
                            <field name="release_date"/>
                        </group>
                    </group>

                    <notebook>
                        <page string="Description">
                            <field name="description" placeholder="Add release notes, summary of features, or bug fixes here."/>
                        </page>
                        <page string="Sprints in Release">
                            <field name="sprint_ids">
                                <list>
                                    <field name="name"/>
                                    <field name="start_date"/>
                                    <field name="end_date"/>
                                    <field name="completed_story_points" string="Completed SP"/>
                                    <field name="state"/>
                                </list>
                            </field>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <!-- Action Window -->
    <record id="action_project_scrum_release" model="ir.actions.act_window">
        <field name="name">Releases</field>
        <field name="res_model">project.scrum.release</field>
        <field name="view_mode">list,form</field>
    </record>

</odoo>