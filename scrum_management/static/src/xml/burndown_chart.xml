<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">
    <t t-name="scrum_management.BurndownChart">
        <div class="bg-white p-4 rounded-4 shadow-sm border mb-4" style="padding-bottom: 2rem !important;">

            <!-- HEADER + SPRINT SELECTOR -->
            <div class="d-flex justify-content-between align-items-center mb-3">
                <div>
                    <h5 class="fw-bold mb-0 text-dark">
                        <i class="fa fa-area-chart text-danger me-2"></i>Sprint Burndown
                        <t t-if="state.selectedSprintData">
                            <small class="text-muted fw-normal ms-1">(<t t-esc="state.selectedSprintData.sprint_name"/>)</small>
                        </t>
                    </h5>
                    <small class="text-muted">Remaining Story Points over Sprint Duration</small>
                </div>

                <!-- SPRINT SELECTOR -->
                <select t-if="state.allData.length"
                        class="form-select form-select-sm shadow-sm"
                        style="width: auto; max-width: 180px; font-size: 0.8rem; cursor: pointer;"
                        t-on-change="onSprintChange">
                    <t t-foreach="state.allData" t-as="sprint" t-key="sprint.sprint_id">
                        <option
                            t-att-value="sprint.sprint_id"
                            t-att-selected="sprint.sprint_id === state.selectedSprintId">
                            <t t-esc="sprint.sprint_name"/>
                            <t t-if="sprint.sprint_state === 'active'"> ●</t>
                        </option>
                    </t>
                </select>
            </div>

            <!-- ERROR -->
            <div t-if="state.error" class="alert alert-danger m-3">
                <i class="fa fa-exclamation-triangle me-2"></i>
                <t t-esc="state.error"/>
            </div>

            <!-- LOADING -->
            <div t-elif="state.loading" class="text-center p-5">
                <i class="fa fa-spinner fa-spin fa-2x text-muted"></i>
            </div>

            <div t-elif="state.selectedSprintData and state.selectedSprintData.start_date">
                <!-- METRICS ROW -->
                <div class="d-flex justify-content-center gap-5 mb-3 pb-3 border-bottom text-muted" style="font-size: 0.95rem;">
                    <div title="Total story points committed for this sprint." style="cursor: help;">
                        <span>Total Points: </span>
                        <strong class="text-primary fs-6"><t t-esc="state.metrics.totalPoints"/> pts</strong>
                    </div>
                    <div title="Story points completed so far." style="cursor: help;">
                        <span>Completed: </span>
                        <strong class="text-success fs-6"><t t-esc="state.metrics.completedPoints"/> pts</strong>
                    </div>
                    <div title="Story points still remaining." style="cursor: help;">
                        <span>Remaining: </span>
                        <strong class="text-danger fs-6"><t t-esc="state.metrics.remainingPoints"/> pts</strong>
                    </div>
                    <div title="Percentage of sprint completed." style="cursor: help;">
                        <span>Progress: </span>
                        <strong class="text-primary fs-6"><t t-esc="state.metrics.percentComplete"/>%</strong>
                    </div>
                </div>

                <!-- CHART CANVAS -->
                <div style="position: relative; height: 400px; width: 100%; overflow: visible;">
                    <canvas t-ref="burndownCanvas"></canvas>
                </div>
            </div>

            <!-- NO DATA -->
            <div t-elif="!state.loading" class="text-center p-4 bg-light rounded text-muted small">
                <i class="fa fa-info-circle me-1"></i>
                No burndown data available for the selected sprint.
            </div>

        </div>
    </t>
</templates>