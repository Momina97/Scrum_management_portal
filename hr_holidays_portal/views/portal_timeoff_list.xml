<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <template id="portal_my_timeoff" name="My Time Off">
        <t t-call="portal.portal_layout">

            <t t-set="breadcrumbs_searchbar" t-value="True"/>
            <t t-call="portal.portal_searchbar">
                <t t-set="title">Time Off</t>
            </t>

            <div class="cymax_timeoff_page">

                <!-- PAGE HEADER -->
                <div class="ct_page_header">
                    <div class="ct_header_left">
                        <h1 class="ct_page_title">Time Off</h1>
                        <p class="ct_page_subtitle">Your leave balance and time off overview.</p>
                    </div>
                    <div class="ct_header_right">
                        <a href="/my/timeoff/requests" class="ct_secondary_btn">
                            My Requests →
                        </a>
                        <a href="/my/timeoff/new" class="ct_primary_btn">
                            + Apply for Leave
                        </a>
                    </div>
                </div>

                <!-- BALANCE CARDS -->
                <t t-if="balance">
                    <div class="ct_section_title">Leave Balance</div>
                    <div class="ct_balance_grid">
                        <t t-foreach="balance" t-as="b">
                            <div class="ct_balance_card">
                                <div class="ct_balance_name">
                                    <t t-esc="b['name']"/>
                                </div>
                                <div class="ct_balance_remaining">
                                    <t t-esc="b['remaining']"/>
                                </div>
                                <div class="ct_balance_meta">
                                    days remaining of <t t-esc="b['allocated']"/>
                                </div>
                                <!-- Progress bar -->
                                <div class="ct_balance_bar_wrap">
                                    <div class="ct_balance_bar" t-att-style="b['bar_style']"/>
                                </div>
                            </div>
                        </t>
                    </div>
                </t>
                <t t-else="">
                    <div class="ct_empty_state">
                        <p>No leave allocations found.</p>
                    </div>
                </t>

                <!-- DASHBOARD LISTS -->
                <div t-attf-class="ct_lists_row#{(' ct_lists_row_single' if not is_approver else '')}">

                    <!-- TO APPROVE (team leads only) -->
                    <t t-if="is_approver">
                        <div class="ct_list_card">
                            <div class="ct_list_head">To Approve</div>
                            <div class="ct_list_body">
                                <t t-if="to_approve">
                                    <t t-foreach="to_approve" t-as="ta">
                                        <div class="ct_list_row">
                                            <div class="ct_list_info">
                                                <span class="ct_list_name">
                                                    <t t-esc="ta.employee_id.name"/>
                                                </span>
                                                <span class="ct_list_dates">
                                                    <span t-field="ta.date_from" t-options='{"widget": "date"}'/>
                                                    —
                                                    <span t-field="ta.date_to" t-options='{"widget": "date"}'/>
                                                </span>
                                            </div>
                                            <div class="ct_list_actions">
                                                <form t-attf-action="/my/timeoff/#{ta.id}/approve"
                                                      method="POST" class="d-inline">
                                                    <input type="hidden" name="csrf_token"
                                                           t-att-value="request.csrf_token()"/>
                                                    <button type="submit" class="ct_action_btn ct_btn_approve">
                                                        Approve
                                                    </button>
                                                </form>
                                                <form t-attf-action="/my/timeoff/#{ta.id}/refuse"
                                                      method="POST" class="d-inline">
                                                    <input type="hidden" name="csrf_token"
                                                           t-att-value="request.csrf_token()"/>
                                                    <button type="submit" class="ct_action_btn ct_btn_refuse"
                                                            onclick="return confirm('Refuse this request?')">
                                                        Reject
                                                    </button>
                                                </form>
                                            </div>
                                        </div>
                                    </t>
                                </t>
                                <t t-else="">
                                    <div class="ct_list_empty">No team requests to approve.</div>
                                </t>
                            </div>
                        </div>
                    </t>

                    <!-- WAITING FOR APPROVAL (own requests) -->
                    <div class="ct_list_card">
                        <div class="ct_list_head">Waiting for Approval</div>
                        <div class="ct_list_body">
                            <t t-if="waiting">
                                <t t-foreach="waiting" t-as="w">
                                    <div class="ct_list_row">
                                        <div class="ct_list_info">
                                            <span class="ct_list_name">
                                                <t t-esc="w.holiday_status_id.name"/>
                                            </span>
                                            <span class="ct_list_dates">
                                                <span t-field="w.date_from" t-options='{"widget": "date"}'/>
                                                —
                                                <span t-field="w.date_to" t-options='{"widget": "date"}'/>
                                            </span>
                                        </div>
                                        <div class="ct_list_actions">
                                            <t t-if="w.state == 'confirm'">
                                                <span class="ct_badge ct_badge_warning">Waiting for Team Lead</span>
                                            </t>
                                            <t t-elif="w.state == 'validate1'">
                                                <span class="ct_badge ct_badge_info">Waiting for Admin</span>
                                            </t>
                                        </div>
                                    </div>
                                </t>
                            </t>
                            <t t-else="">
                                <div class="ct_list_empty">No pending requests.</div>
                            </t>
                        </div>
                    </div>

                </div>

            </div>

        </t>
    </template>

</odoo>