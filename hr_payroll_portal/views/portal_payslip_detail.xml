<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <template id="portal_payslip_detail" name="Payslip Detail">
        <t t-call="portal.portal_layout">

            <t t-set="breadcrumbs_searchbar" t-value="True"/>
            <t t-call="portal.portal_searchbar">
                <t t-set="title">Payslips</t>
            </t>

            <div class="cymax_payslips_page">

                <!-- PAGE HEADER -->
                <div class="cp_page_header">
                    <div class="cp_header_left">
                        <h1 class="cp_page_title">
                            <t t-esc="payslip.name"/>
                        </h1>
                        <!-- Inline metadata -->
                        <div class="cp_detail_meta">
                            <span>
                                <span t-field="payslip.date_from" t-options='{"widget": "date"}'/>
                                —
                                <span t-field="payslip.date_to" t-options='{"widget": "date"}'/>
                            </span>
                            <span class="cp_meta_divider">·</span>
                            <span><t t-esc="payslip.employee_id.name"/></span>
                            <span class="cp_meta_divider">·</span>
                            <span><t t-esc="payslip.contract_id.name"/></span>
                        </div>
                    </div>
                    <div class="cp_header_right">
                        <a t-attf-href="/my/payslips/#{payslip.id}/download"
                           class="cp_download_btn">
                            Download PDF
                        </a>
                        <a href="/my/payslips/list" class="cp_back_btn">
                            ← Back
                        </a>
                    </div>
                </div>

                <!-- EARNINGS TABLE -->
                <div class="cp_section_title">Earnings</div>
                <div class="cp_table_wrapper mb-24">
                    <table class="cp_table">
                        <thead>
                            <tr>
                                <th>Description</th>
                                <th class="text-end">Amount</th>
                            </tr>
                        </thead>
                        <tbody>
                            <t t-foreach="earnings" t-as="line">
                                <tr>
                                    <td><t t-esc="line.name"/></td>
                                    <td class="text-end"><t t-esc="line.total"/></td>
                                </tr>
                            </t>
                        </tbody>
                        <tfoot>
                            <tr class="cp_tfoot_row">
                                <td>Gross</td>
                                <td class="text-end"><t t-esc="payslip.gross_wage"/></td>
                            </tr>
                        </tfoot>
                    </table>
                </div>

                <!-- NET PAY SUMMARY -->
                <div class="cp_net_pay_row">
                    <span class="cp_net_pay_label">Net Pay</span>
                    <span class="cp_net_pay_value">
                        <t t-esc="payslip.net_wage"/>
                    </span>
                </div>

            </div>
        </t>
    </template>

</odoo>