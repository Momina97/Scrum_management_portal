<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <template id="portal_my_attendance" name="My Attendance">
        <t t-call="portal.portal_layout">

            <t t-set="breadcrumbs_searchbar" t-value="True"/>

            <t t-call="portal.portal_searchbar">
                <t t-set="title">My Attendance</t>
            </t>

            <div class="cymax_attendance_page">

                <!-- PAGE HEADER -->
                <div class="ca_page_header">
                    <div class="ca_header_left">
                        <h1 class="ca_page_title">My Attendance</h1>
                        <p class="ca_page_subtitle">Track your check-ins, worked hours and overtime</p>
                    </div>
                    <div class="ca_header_right">
                        <a href="/my/attendance" class="ca_secondary_btn">Back to Dashboard</a>
                        <form method="GET" action="/my/attendance/list"
                              class="ca_filter_form"
                              id="attendance_filter_form">
                            <input type="hidden" name="sort_field" t-att-value="sort_field"/>
                            <input type="hidden" name="sort_order" t-att-value="sort_order"/>
                            <select name="filter_year" class="ca_select"
                                    onchange="document.getElementById('attendance_filter_form').submit()">
                                <option value="">All Years</option>
                                <t t-foreach="years" t-as="year">
                                    <option t-att-value="year"
                                            t-att-selected="str(year) == filter_year">
                                        <t t-esc="year"/>
                                    </option>
                                </t>
                            </select>
                            <select name="filter_month" class="ca_select"
                                    onchange="document.getElementById('attendance_filter_form').submit()">
                                <option value="">All Months</option>
                                <t t-foreach="months" t-as="month">
                                    <option t-att-value="month[0]"
                                            t-att-selected="month[0] == filter_month">
                                        <t t-esc="month[1]"/>
                                    </option>
                                </t>
                            </select>
                            <a href="/my/attendance/list" class="ca_reset_btn">Reset</a>
                        </form>
                    </div>
                </div>

                <!-- ATTENDANCE TABLE -->
                <div class="ca_table_wrapper">
                    <t t-if="attendances">
                        <table class="ca_table">
                            <thead>
                                <tr>
                                    <th class="ca_sortable_th">
                                        <a class="ca_sort_link"
                                           t-attf-href="/my/attendance/list?filter_year=#{filter_year}&amp;filter_month=#{filter_month}&amp;sort_field=check_in&amp;sort_order=#{'asc' if sort_field == 'check_in' and sort_order == 'desc' else 'desc'}">
                                            Date
                                            <t t-if="sort_field == 'check_in'">
                                                <t t-if="sort_order == 'asc'">▲</t>
                                                <t t-else="">▼</t>
                                            </t>
                                            <t t-else="">
                                                <span class="ca_sort_icon_idle">↕</span>
                                            </t>
                                        </a>
                                    </th>
                                    <th>Check In</th>
                                    <th>Check Out</th>
                                    <th class="ca_sortable_th">
                                        <a class="ca_sort_link"
                                           t-attf-href="/my/attendance/list?filter_year=#{filter_year}&amp;filter_month=#{filter_month}&amp;sort_field=worked_hours&amp;sort_order=#{'asc' if sort_field == 'worked_hours' and sort_order == 'desc' else 'desc'}">
                                            Worked Hours
                                            <t t-if="sort_field == 'worked_hours'">
                                                <t t-if="sort_order == 'asc'">▲</t>
                                                <t t-else="">▼</t>
                                            </t>
                                            <t t-else="">
                                                <span class="ca_sort_icon_idle">↕</span>
                                            </t>
                                        </a>
                                    </th>
                                    <th class="ca_sortable_th">
                                        <a class="ca_sort_link"
                                           t-attf-href="/my/attendance/list?filter_year=#{filter_year}&amp;filter_month=#{filter_month}&amp;sort_field=overtime_hours&amp;sort_order=#{'asc' if sort_field == 'overtime_hours' and sort_order == 'desc' else 'desc'}">
                                            Extra Hours
                                            <t t-if="sort_field == 'overtime_hours'">
                                                <t t-if="sort_order == 'asc'">▲</t>
                                                <t t-else="">▼</t>
                                            </t>
                                            <t t-else="">
                                                <span class="ca_sort_icon_idle">↕</span>
                                            </t>
                                        </a>
                                    </th>
                                    <th>Overtime Status</th>
                                </tr>
                            </thead>
                            <tbody>
                                <t t-foreach="attendances" t-as="att">
                                    <tr>
                                        <td>
                                            <span t-field="att.check_in"
                                                  t-options='{"widget": "date"}'/>
                                        </td>
                                        <td>
                                            <span t-field="att.check_in"
                                                  t-options='{"widget": "datetime", "format": "HH:mm"}'/>
                                        </td>
                                        <td>
                                            <t t-if="att.check_out">
                                                <span t-field="att.check_out"
                                                      t-options='{"widget": "datetime", "format": "HH:mm"}'/>
                                            </t>
                                            <t t-else="">
                                                <span class="ca_badge ca_badge_working">Currently Working</span>
                                            </t>
                                        </td>
                                        <td>
                                            <t t-if="att.worked_hours">
                                                <t t-esc="'%02d:%02d' % (int(att.worked_hours), int((att.worked_hours % 1) * 60))"/>
                                            </t>
                                            <t t-else="">—</t>
                                        </td>
                                        <td>
                                            <t t-if="att.overtime_hours">
                                                <t t-esc="'%02d:%02d' % (int(att.overtime_hours), int((att.overtime_hours % 1) * 60))"/>
                                            </t>
                                            <t t-else="">—</t>
                                        </td>
                                        <td>
                                            <t t-if="att.overtime_hours">
                                                <t t-if="att.overtime_status == 'approved'">
                                                    <span class="ca_badge ca_badge_approved">Approved</span>
                                                </t>
                                                <t t-elif="att.overtime_status == 'to_approve'">
                                                    <span class="ca_badge ca_badge_pending">Pending</span>
                                                </t>
                                                <t t-elif="att.overtime_status == 'refused'">
                                                    <span class="ca_badge ca_badge_refused">Refused</span>
                                                </t>
                                                <t t-else="">
                                                    <span class="text-muted">—</span>
                                                </t>
                                            </t>
                                            <t t-else="">
                                                <span class="text-muted">—</span>
                                            </t>
                                        </td>
                                    </tr>
                                </t>
                            </tbody>
                        </table>
                        <div t-if="pager" class="o_portal_pager text-center mt-3">
                            <t t-call="portal.pager"/>
                        </div>
                    </t>
                    <t t-else="">
                        <div class="ca_empty_state">
                            <p>No attendance records found.</p>
                        </div>
                    </t>
                </div>

            </div>

        </t>
    </template>
</odoo>