<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ============================================================
         SUBTASK NEW — creation form
    ============================================================ -->
    <template id="portal_subtask_new" name="New Subtask">
        <t t-call="portal.portal_layout">
            <div class="cymax_scrum_page">

                <div class="scrum_page_header">
                    <a t-attf-href="/my/scrum/projects/#{project.id}/tasks/#{task.id}"
                    class="scrum_back_link">
                        <i class="fa fa-arrow-left me-1"/><t t-esc="task.name"/>
                    </a>
                    <h1 class="scrum_page_title mt-1">Add Subtask</h1>
                    <p class="scrum_page_subtitle">
                        Creating a subtask under: <strong><t t-esc="task.name"/></strong>
                    </p>
                </div>

                <div class="scrum_edit_layout">

                    <!-- LEFT: Form -->
                    <div class="scrum_edit_main">
                        <div class="scrum_form_card" style="max-width: 100%;">

                            <t t-if="error">
                                <div class="scrum_alert_danger">
                                    <i class="fa fa-exclamation-circle me-2"/>
                                    <t t-esc="error"/>
                                </div>
                            </t>

                            <form method="POST"
                                t-attf-action="/my/scrum/projects/#{project.id}/tasks/#{task.id}/subtask/new">
                                <input type="hidden" name="csrf_token"
                                    t-att-value="request.csrf_token()"/>

                                <div class="scrum_form_group">
                                    <label for="name" class="scrum_form_label">
                                        Subtask Name
                                    </label>
                                    <input type="text"
                                        class="scrum_form_input"
                                        id="name"
                                        name="name"
                                        required="1"
                                        placeholder="Enter subtask name..."/>
                                </div>

                                <div class="d-flex gap-2 mt-4">
                                    <button type="submit" class="scrum_btn_primary">
                                        <i class="fa fa-plus me-1"/>Create Subtask
                                    </button>
                                    <a t-attf-href="/my/scrum/projects/#{project.id}/tasks/#{task.id}"
                                    class="scrum_btn_outline">
                                        Cancel
                                    </a>
                                </div>
                            </form>
                        </div>
                    </div>

                    <!-- RIGHT: Info panel -->
                    <div class="scrum_edit_sidebar">
                        <div class="scrum_info_panel">
                            <div class="scrum_info_panel_header">
                                <i class="fa fa-info-circle me-2"/>Details
                            </div>
                            <div class="scrum_info_row">
                                <span class="scrum_info_label">Project</span>
                                <span class="scrum_info_value">
                                    <t t-esc="project.name"/>
                                </span>
                            </div>
                            <div class="scrum_info_row">
                                <span class="scrum_info_label">Parent Task</span>
                                <span class="scrum_info_value">
                                    <t t-esc="task.name"/>
                                </span>
                            </div>
                            <div class="scrum_info_row">
                                <span class="scrum_info_label">Stage</span>
                                <span class="scrum_info_value">
                                    <span t-attf-class="scrum_stage_badge scrum_stage_#{task.stage_id.category or 'new'}">
                                        <t t-esc="task.stage_id.name"/>
                                    </span>
                                </span>
                            </div>
                        </div>
                    </div>

                </div>
            </div>
        </t>
    </template>

</odoo>
