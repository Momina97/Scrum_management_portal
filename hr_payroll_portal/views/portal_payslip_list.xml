<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <template id="portal_my_payslips" name="My Payslips">
        <t t-call="portal.portal_layout">

            <t t-set="breadcrumbs_searchbar" t-value="True"/>

            <t t-call="portal.portal_searchbar">
                <t t-set="title">Payslips</t>
            </t>

            <div class="cymax_payslips_page">

                <!-- PAGE HEADER -->
                <div class="cp_page_header">
                    <div class="cp_header_left">
                        <h1 class="cp_page_title">My Payslips</h1>
                        <p class="cp_page_subtitle">View your salary history and download payslips</p>
                    </div>
                    <div class="cp_header_right">
                        <a href="/my/payslips" class="cp_reset_btn">Back to Dashboard</a>
                        <form method="GET" action="/my/payslips"
                            class="cp_filter_form"
                            id="payslip_filter_form">
                            <select name="filter_year" class="cp_select"
                                    onchange="document.getElementById('payslip_filter_form').submit()">
                                <option value="">All Years</option>
                                <t t-foreach="years" t-as="year">
                                    <option t-att-value="year"
                                            t-att-selected="str(year) == filter_year">
                                        <t t-esc="year"/>
                                    </option>
                                </t>
                            </select>
                            <select name="filter_month" class="cp_select"
                                    onchange="document.getElementById('payslip_filter_form').submit()">
                                <option value="">All Months</option>
                                <t t-foreach="months" t-as="month">
                                    <option t-att-value="month[0]"
                                            t-att-selected="month[0] == filter_month">
                                        <t t-esc="month[1]"/>
                                    </option>
                                </t>
                            </select>
                            <a href="/my/payslips/list" class="cp_reset_btn">Reset</a>
                        </form>
                    </div>
                </div>

                <!-- PAYSLIPS TABLE -->
                <div class="cp_table_wrapper">
                    <t t-if="payslips">
                        <table class="cp_table">
                            <thead>
                                <tr>
                                    <th>Reference</th>
                                    <th>Period</th>
                                    <th>Gross</th>
                                    <th>Net</th>
                                    <th class="text-center">Download</th>
                                </tr>
                            </thead>
                            <tbody>
                                <t t-foreach="payslips" t-as="payslip">
                                    <tr>
                                        <td>
                                            <a t-attf-href="/my/payslips/#{payslip.id}"
                                               class="cp_link">
                                                <t t-esc="payslip.name"/>
                                            </a>
                                        </td>
                                        <td>
                                            <span t-field="payslip.date_from"
                                                  t-options='{"widget": "date"}'/>
                                            —
                                            <span t-field="payslip.date_to"
                                                  t-options='{"widget": "date"}'/>
                                        </td>
                                        <td><t t-esc="payslip.gross_wage"/></td>
                                        <td><t t-esc="payslip.net_wage"/></td>
                                        <td class="text-center">
                                            <a t-attf-href="/my/payslips/#{payslip.id}/download"
                                               class="cp_download_icon"
                                               title="Download PDF">
                                                <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                                    <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/>
                                                    <polyline points="7 10 12 15 17 10"/>
                                                    <line x1="12" y1="15" x2="12" y2="3"/>
                                                </svg>
                                            </a>
                                        </td>
                                    </tr>
                                </t>
                            </tbody>
                        </table>
                        <div t-if="pager" class="o_portal_pager text-center mt-3">
                            <t t-call="portal.pager"/>
                        </div>
                    </t>
                    <t t-else="">
                        <div class="cp_empty_state">
                            <p>No payslips found.</p>
                        </div>
                    </t>
                </div>

            </div>

        </t>
    </template>

</odoo>